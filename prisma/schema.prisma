generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String
  role          Role      @default(USER)
  orders        Order[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Order {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  items         Json      // Array of order items
  total         Float
  status        OrderStatus @default(PENDING)
  pickupCode    String    // 6-digit code provided on Ready
  paymentMethod String    @default("Bank Transfer")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  price       Float
  description String
  imageUrl    String
  category    String   @default("Food")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  PREPARING
  READY_FOR_PICKUP
  DELIVERED
  CANCELLED
}
